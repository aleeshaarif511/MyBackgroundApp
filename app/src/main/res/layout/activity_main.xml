<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:gravity="center"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp"
    android:background="#F5F5F5">

    <TextView
        android:id="@+id/tv_info"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Checking permissions..."
        android:textSize="18sp"
        android:textColor="#333333"
        android:gravity="center"
        android:padding="16dp" />

    <Button
        android:id="@+id/btn_open_settings"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Allow Background Permission"
        android:layout_marginTop="24dp"/>

    <Button
        android:id="@+id/btn_enable_bt"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Enable Bluetooth  Request Permissions"
        android:layout_marginTop="24dp"/>
    <Button
        android:id="@+id/btn_voice_input"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Voice Input for Insulin" />

    <Button
        android:id="@+id/btn_view_entries"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="View Insulin Entries" />


</LinearLayout>
